{
  "name": "turku-analiz-platformu",
  "version": "1.0.0",
  "description": "Öğretim Temelli Türkü Sınıflandırma ve Analiz Platformu",
  "private": true,
  "scripts": {
    "server": "node server/index.js",
    "client": "cd client && npm run dev",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "build": "cd client && npm install && npm run build",
    "start": "node server/index.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.7.0",
    "cheerio": "^1.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.0",
    "iconv-lite": "^0.6.3",
    "jsonwebtoken": "^9.0.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "axios-cookiejar-support": "^6.0.5",
    "concurrently": "^9.1.0",
    "tough-cookie": "^6.0.1"
  }
}
